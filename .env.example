# === Engine Connection ===
# The CueCrux Engine endpoint to benchmark against.
BENCH_TARGET=http://127.0.0.1:3333

# Engine API key (must match the running Engine instance).
API_KEY=your-api-key-here

# Postgres connection string for the Engine database.
# Used by Cat 4 (temporal edge cases) for direct DB state checks,
# and by all categories for corpus insertion.
DATABASE_URL=postgres://cuecrux:password@127.0.0.1:5432/engine

# === Embeddings ===
# Which embedding provider the audit suite uses to embed corpus documents.
#   "openai"       — OpenAI API (requires OPENAI_API_KEY)
#   "embeddercrux" — Local EmbedderCrux/TEI server (requires EMBEDDERCRUX_BASE_URL)
#   "ollama"       — Ollama with embedding model
#   "local"        — Alias for embeddercrux
#
# IMPORTANT: This must match the embedding provider used by the Engine instance.
# If the Engine uses embeddercrux with nomic-embed-text-v1.5, the audit suite
# must also use embeddercrux. Mismatched embedding spaces produce meaningless
# retrieval results because cosine similarity is only valid within a single
# embedding space.
AUDIT_EMBEDDING_PROVIDER=openai

# OpenAI API key (required when AUDIT_EMBEDDING_PROVIDER=openai).
OPENAI_API_KEY=sk-your-key-here

# EmbedderCrux base URL (required when AUDIT_EMBEDDING_PROVIDER=embeddercrux).
# EMBEDDERCRUX_BASE_URL=http://127.0.0.1:8080

# Embedding dimension. Must match the Engine's VECTOR_DIM or lane dimension.
EMBEDDING_DIM=768

# === Rate Limits ===
# The Engine's /v1/answers endpoint has a per-minute rate limit.
# Cat 5 alone issues 50 queries. Set this high enough to avoid 429s.
# This value must be set in the ENGINE's environment, not here.
# ANSWERS_RATE_LIMIT_MAX=5000

# === Feature Flags ===
# FEATURE_EMBEDDING_JOBS controls whether the Engine auto-embeds ingested
# documents. When false (default), documents ingested via /internal/ingest
# will NOT be embedded and will be invisible to /v1/answers retrieval.
# The audit suite bypasses this by inserting embeddings directly via SQL,
# but production deployments MUST set this to true.
# FEATURE_EMBEDDING_JOBS=true
